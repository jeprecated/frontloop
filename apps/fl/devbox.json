{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.15.0/.schema/devbox.schema.json",
  "packages": [
    "go@latest",
    "gopls@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "build": [
        "go build -o fl ./cmd/fl"
      ],
      "test": [
        "go test -v ./..."
      ]
    }
  }
}
